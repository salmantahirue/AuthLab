# Copy this file to .env and fill in your values (optional for local learning).
# The app works with defaults if .env is missing; use .env in production!

# Secret key for signing JWTs. MUST be long, random, and secret in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# How long the access token is valid (minutes). 30 = 30 minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Algorithm for JWT (you usually don't change this)
# ALGORITHM=HS256
